# 服务器配置
SERVER_PORT: "8080"
MODE: "debug"
LOG_LEVEL: "info"

# 数据库配置
DATABASE:
  DB_HOST: "localhost"
  DB_PORT: "3306"
  DB_USER: "your_db_user"
  DB_PASSWORD: "your_db_password"
  DB_NAME: "vital_fitness"

# JWT配置
JWT:
  JWT_SECRET: "your_jwt_secret_key_here"
  JWT_EXPIRE: 24

# 微信小程序配置
WECHAT:
  WX_APP_ID: "your_wx_app_id"
  WX_APP_SECRET: "your_wx_app_secret"
